# ========================================
# Docker 构建忽略文件（优化版）
# ========================================

# ========================================
# Git 和版本控制
# ========================================
.git
.gitignore
.gitattributes
.github

# ========================================
# 环境配置文件（敏感信息）
# ========================================
.env
.env.local
.env.development
.env.*.local
server/.env
admin/.env
pc/.env
uniapp/.env*

# ========================================
# 安装锁文件（允许重新安装）
# ========================================
server/config/install.lock

# ========================================
# 日志和缓存
# ========================================
*.log
*.cache
server/runtime/*
!server/runtime/.gitkeep

# ========================================
# 依赖目录（会在镜像中重新安装）
# ========================================
vendor/*
!vendor/.gitkeep
node_modules/
admin/node_modules/
pc/node_modules/
uniapp/node_modules/

# ========================================
# 构建产物（某些会在镜像中重新构建）
# ========================================
admin/dist/
pc/dist/
uniapp/dist/
build/
dist/

# ========================================
# 缓存目录
# ========================================
.cache/
.parcel-cache/
.vite/
.nuxt/
.output/

# ========================================
# IDE 和编辑器
# ========================================
.idea/
.vscode/
*.swp
*.swo
*~

# ========================================
# 操作系统文件
# ========================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ========================================
# 测试和覆盖率
# ========================================
tests/
*.test.js
*.spec.js
coverage/
.nyc_output/

# ========================================
# 文档（可选保留在镜像中）
# ========================================
# README.md
# *.md
# docs/
# LICENSE.txt

# ========================================
# Docker 文件本身
# ========================================
Dockerfile*
docker-compose*.yml
.dockerignore
.docker/

# ========================================
# 临时文件
# ========================================
*.bak
*.tmp
*.temp

# ========================================
# 调试日志
# ========================================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
