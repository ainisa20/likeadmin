# Git
.git
.gitignore

# 文档
README.md
*.md
LICENSE.txt

# 环境配置
.env
.env.*

# 安装锁文件（必须排除，允许重新安装）
server/config/install.lock

# 日志和缓存
*.log
*.cache
server/runtime/*
!server/runtime/.gitkeep

# 依赖包（vendor 会被重新安装）
vendor/*
!vendor/.gitkeep

# 前端依赖和构建产物
node_modules/
admin/node_modules/
pc/node_modules/
uniapp/node_modules/
admin/dist/
pc/dist/
uniapp/dist/

# IDE 和系统文件
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
*~

# 临时文件
*.bak
*.tmp
*.temp

# 构建目录
build/
dist/
.cache/

# 测试和覆盖率
coverage/
.nyc_output/

# 其他
npm-debug.log*
yarn-debug.log*
yarn-error.log*
