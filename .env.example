# ========================================
# Docker 环境变量配置示例
# ========================================
# 复制此文件为 .env 并修改密码

# 端口配置
NGINX_PORT=18088
MYSQL_PORT=13306
REDIS_PORT=16397
PHPMYADMIN_PORT=18089

# 数据库配置
DB_DATABASE=likeadmin
DB_USERNAME=root
DB_PASSWORD=your_secure_password_here

# Redis 配置
REDIS_PASSWORD=

# PHP 配置
PHP_MEMORY_LIMIT=256M
PHP_UPLOAD_MAX_FILESIZE=50M
PHP_POST_MAX_SIZE=50M

# 时区配置
TZ=Asia/Shanghai
